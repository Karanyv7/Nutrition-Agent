# ─────────────────────────────────────────────────────
#  Nutrition Agent — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────

# IBM Cloud API Key (from IBM Cloud → Manage → Access → API keys)
IBM_API_KEY=your_api_key_here

# IBM Watsonx.ai Project ID (from your Watsonx.ai project settings)
IBM_PROJECT_ID=your_project_id_here

# IBM Watsonx.ai service URL (default: us-south)
IBM_URL=your_ibm_watson_URL

# Granite model to use
# Options: ibm/granite-13b-instruct-v2 | ibm/granite-8b-code-instruct
#          ibm/granite-3-8b-instruct   | ibm/granite-20b-multilingual
# GRANITE_MODEL=ibm/granite-4-h-small

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-secret-string
FLASK_DEBUG=false
PORT=5000
